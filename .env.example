# Driftibo environment. Copy to .env.local and fill in. Everything below the Supabase
# block is OPTIONAL — the site runs fully without them; each feature stays inert until its
# keys are pasted (analytics no-ops, deposit button hidden, emails skipped, crons 401).

# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── AI image generation (admin tooling only; optional) ──
VERTEX_AI_API_KEY=

# ── Server-only Supabase service role (optional; needed only by /api/cron/* to read leads,
#    since captures SELECT is admin-only and a cron has no user session). Never expose client-side. ──
SUPABASE_SERVICE_ROLE_KEY=

# ── Analytics (optional — track() no-ops, no tags rendered, until set) ──
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# ── Payments: Razorpay "hold my dates" deposit (optional — button hidden until KEY_ID set) ──
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Transactional email: Resend (optional — lead/founder emails skipped until set) ──
RESEND_API_KEY=
RESEND_FROM=Driftibo <hello@driftibo.com>
RESEND_FOUNDER_EMAIL=travel@driftibo.com

# ── Coming-soon gate (optional — unset locally to serve the real site) ──
# Only 1/true/yes/on enable the gate; to disable, remove the variable or leave it empty (setting 0/false also disables now).
COMING_SOON=
# Founder preview bypass: /?preview=<PREVIEW_SECRET> sets an httpOnly preview cookie.
PREVIEW_SECRET=

# ── Cron auth: shared secret guarding /api/cron/* (optional — crons 401 without it) ──
CRON_SECRET=
