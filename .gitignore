# DesignSync tooling state (local mirror, not source)
.design-sync/

# local env / secrets — never commit
.env*.local

# Driftibo generation pipeline — never commit secrets, sessions, or generated media
**/pipeline/.env
**/.grok-auth.json
**/pipeline/out/
**/pipeline/anchors/
**/pipeline/music/

# Driftibo growth-agent — never commit the review queue, sessions, secrets, or generated assets
# (redline: no committed secrets/sessions/generated media — [rules-of-the-road.md §6])
**/growth-agent/.env
**/growth-agent/.sessions/
**/growth-agent/out/
**/growth-agent/*.session.json
**/growth-agent/.*-auth.json

# generated overlay renders (large, lossless)
**/templates/overlays/*.mov
**/templates/overlays/*.webm

# ── Secrets & credential screenshots — never commit (safety net) ──
# General env catch-all (in addition to the specific pipeline/growth-agent rules above)
.env
**/.env
